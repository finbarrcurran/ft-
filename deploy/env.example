# /etc/ft/env — copy to /etc/ft/env and fill in.
# Read by ft.service via systemd's EnvironmentFile=.
# Mode 0600, owned root:root. Never commit real values.
#
# Spec 12 D10b. The Settings → Diagnostics panel (Spec 7) reads each key
# and surfaces a green/red dot per provider so missing entries are visible.

# ===========================================================================
# Market data — stocks
# ===========================================================================

# Finnhub (primary US-stock quote provider; free tier 60 req/min).
# Sign up: https://finnhub.io/register
FT_FINNHUB_API_KEY=

# TwelveData (fallback; free tier 8 req/min, 800/day).
# Note: TwelveData's free tier went US-only mid-2024 — kept for option value
# only. Yahoo (no key) handles non-US tickers.
# Sign up: https://twelvedata.com/register
FT_TWELVEDATA_API_KEY=

# ===========================================================================
# News — fills the News + Crypto News tabs and the F&G chips (Spec 12 D10a).
# Refresh strategy: 14-minute cache so ≈ 96 calls / 24h, well under the
# 100-call/day NewsAPI free-tier budget.
# ===========================================================================

# NewsAPI — drives the News tab. Free tier 100 req/24h.
# Sign up: https://newsapi.org/register
NEWSAPI_API_KEY=

# CryptoPanic — drives the Crypto News tab. Free tier ample for personal use.
# Sign up: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# ===========================================================================
# LLM (Spec 9c.1)
# ===========================================================================
# Anthropic API key for the LLM choke-point service. Service is nil-safe —
# every gated call rejects with ErrAPIKeyMissing until this is set. Wire
# the budget gate + usage log work either way.
# Sign up: https://console.anthropic.com/
FT_ANTHROPIC_API_KEY=

# ===========================================================================
# Telegram (FT bot)
# ===========================================================================
# Used by FT (not by ft-bot — that has its own /etc/ft-bot/env) for the
# threshold-alert sender in Spec 9c.1's alerts.go. Optional; LLM cost
# discipline works without it (it just won't send Telegram notifications
# at threshold crossings).
FT_TELEGRAM_BOT_TOKEN=
FT_TELEGRAM_CHAT_ID=

# ===========================================================================
# Runtime overrides (rarely needed)
# ===========================================================================
# FT_REFRESH_INTERVAL — 0 disables auto-refresh; default 15m.
# FT_DB_PATH         — default /var/lib/ft/ft.db.
# FT_ADDR            — default 127.0.0.1:8081.
