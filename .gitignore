# Secrets — never commit
env
.env
*.env
/etc/ft/env

# Build artifacts
# Note: the binary name `ft` matches a package dir under cmd/, so we anchor
# to the root /bin/ directory — never use a bare `ft` rule.
/bin/

# Database
*.db
*.db-journal
*.db-wal
*.db-shm
data/

# Embedded asset sync output (regenerated by `make sync-assets`)
internal/web/assets/*
!internal/web/assets/.gitkeep

# OS / editor noise
.DS_Store
.vscode/
.idea/
*.swp
*~

# Logs
*.log
